DROP TABLE genero_filme CASCADE CONSTRAINTS;

-- 2. APAGANDO TABELAS INTERMEDIÁRIAS
DROP TABLE figurino CASCADE CONSTRAINTS;
DROP TABLE ator_filme CASCADE CONSTRAINTS;
DROP TABLE filme CASCADE CONSTRAINTS;

-- 3. APAGANDO ESPECIALIZAÇÕES E ATRIBUTOS MULTIVALORADOS/COMPOSTOS
DROP TABLE ator CASCADE CONSTRAINTS;
DROP TABLE figurinista CASCADE CONSTRAINTS;
DROP TABLE diretor CASCADE CONSTRAINTS;
DROP TABLE dependente CASCADE CONSTRAINTS;
DROP TABLE telefone_funcionario CASCADE CONSTRAINTS;
DROP TABLE endereco_funcionario CASCADE CONSTRAINTS;

-- 4. APAGANDO AS TABELAS FORTES (INDEPENDENTES)
DROP TABLE funcionario CASCADE CONSTRAINTS;
DROP TABLE estudio CASCADE CONSTRAINTS;
DROP TABLE fornecedor CASCADE CONSTRAINTS;
DROP TABLE equipamento CASCADE CONSTRAINTS;

-- 5. APAGANDO AS SEQUENCES
DROP SEQUENCE seq_equipamento;
DROP SEQUENCE seq_estudio;
DROP SEQUENCE seq_filme;
DROP SEQUENCE seq_figurino;
